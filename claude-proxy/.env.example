# Server
PORT=3456
HOST=127.0.0.1

# Auth del proxy (per proteggere l'accesso)
# Lascia vuoto per disabilitare l'autenticazione (solo sviluppo locale)
PROXY_API_KEY=your-secret-key-here

# Provider (cli | token | browser)
PROVIDER=cli

# Claude Code CLI path (se non in PATH)
CLAUDE_CLI_PATH=claude

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=10
MAX_CONCURRENT_REQUESTS=2
QUEUE_MAX_SIZE=50
REQUEST_TIMEOUT_MS=120000

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_COOLDOWN_MS=60000

# Logging
LOG_LEVEL=info
